# Setting up plotting function

# This cell contains the plotting function_no edit it.
output_notebook()
def plot_snps_gRNA(df, gRNA_start_end=None, ref_color="#1f77b4", alt_color="#ff7f0e"):
    df = df.copy().reset_index()
    df['ref_freq'] = 1 - df['max_af']
    df['alt_freq'] = df['max_af']
    df['top'] = 1

    source = ColumnDataSource(df)

    positions = sorted(df['position'].unique())
    min_dist = min([j - i for i, j in zip(positions[:-1], positions[1:])]) if len(positions) > 1 else 1
    bar_width = min_dist * 0.8

    wheel_zoom_x = WheelZoomTool(dimensions="width")
    p = figure(
        width=900, height=250,
        x_axis_label="Position", y_axis_label="Allele frequency",
        tools="pan,box_zoom,reset,save",
        title=f"Allele Frequencies by Position in {transcript}",
        y_range=(0, 1)
    )
    p.add_tools(wheel_zoom_x)
    p.toolbar.active_scroll = wheel_zoom_x

    # Capture the list of glyph renderers returned by vbar_stack
    bars = p.vbar_stack(
        stackers=['ref_freq', 'alt_freq'],
        x='position',
        width=bar_width,
        color=[ref_color, alt_color],
        legend_label=['Reference', 'Alternative'],
        source=source
    )

    # Invisible bar for hover
    hover_bar = p.vbar(
        x='position',
        top='top',
        width=bar_width,
        source=source,
        fill_alpha=0,
        line_alpha=0
    )

    # Hover tool attached only to invisible bar
    hover = HoverTool(
        tooltips=[
            ("Position", "@position{0,0}"),
            ("Reference freq", "@ref_freq{0.00}"),
            ("Alternative freq", "@alt_freq{0.00}")
        ],
        renderers=[hover_bar],
        mode='vline'
    )
    p.add_tools(hover)

    # Format axes
    p.xaxis.formatter = NumeralTickFormatter(format="0,0")
    p.xaxis.major_label_orientation = 0
    p.xaxis.major_label_text_font_size = "10pt"
    p.xaxis.minor_tick_line_color = None

    p.legend.location = "top_right"
    p.legend.click_policy = "hide"

    # Highlight regions *behind* the bars
    if gRNA_start_end:
        for start, end in gRNA_start_end:
            highlight = BoxAnnotation(
                left=start-0.5,
                right=end+0.5,
                fill_alpha=0.2,
                fill_color="green",
                level="underlay",
                editable=False,
                propagate_hover=True
            )
            p.add_layout(highlight)

            # Keep the vertical dashed lines on top so they remain visible
            p.add_layout(Span(location=start-0.5, dimension='height',
                              line_color='green', line_dash='dashed',
                              line_width=2, level='overlay'))
            p.add_layout(Span(location=end+0.5, dimension='height',
                              line_color='green', line_dash='dashed',
                              line_width=2, level='overlay'))

    # dynamic tick spacing callback (unchanged)
    callback = CustomJS(args=dict(xaxis=p.xaxis[0]), code="""
        const start = Math.floor(cb_obj.start);
        const end = Math.ceil(cb_obj.end);
        const range = end - start;

        let spacing;
        if (range > 100000) {
            spacing = 10000;
        } else if (range > 10000) {
            spacing = 1000;
        } else if (range > 1000) {
            spacing = 100;
        } else if (range > 100) {
            spacing = 10;
        } else {
            spacing = 1;
        }

        let ticks = [];
        for (let i = Math.ceil(start/spacing)*spacing; i <= end; i += spacing) {
            ticks.push(i);
        }

        xaxis.ticker = ticks;
    """)
    p.x_range.js_on_change('start', callback)
    p.x_range.js_on_change('end', callback)

    show(p)
    
